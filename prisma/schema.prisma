generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum PaymentStatus {
  PENDING
  APPROVED
  FAILED
  REFUNDED
  REJECTED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
}

enum ExpenseStatus {
  PENDING
  PAID
  OVERDUE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

// ==========================================
// MODELS
// ==========================================

model Guest {
  id                 String        @id @default(uuid())
  name               String
  phone              String?       
  email              String?
  rsvpStatus         RsvpStatus    @default(PENDING)
  allowedCompanions Int           @default(0)
  hasReceivedMessage Boolean       @default(false) 
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  tableId            String?
  table              Table?        @relation(fields: [tableId], references: [id])

  transactions       Transaction[] 

  @@map("guests")
}

model Table {
  id          String   @id @default(uuid())
  name        String
  capacity    Int      @default(10)
  createdAt   DateTime @default(now())

  guests      Guest[]

  @@map("tables")
}

model Gift {
  id          String        @id @default(uuid())
  title       String
  description String?
  amount      Int           
  imageUrl    String?
  isPurchased Boolean       @default(false)
  createdAt   DateTime      @default(now())

  transactions Transaction[]

  @@map("gifts")
}

model Transaction {
  id                String        @id @default(uuid())
  gatewayId         String?       
  guestName         String?
  amount            Int           
  netAmount         Int?          
  fee               Int?          @default(0)
  paymentMethod     PaymentMethod 
  status            PaymentStatus @default(PENDING)
  externalReference String?       
  thankYouSent      Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt

  giftId            String
  gift              Gift          @relation(fields: [giftId], references: [id])
  guestId           String?       
  guest             Guest?        @relation(fields: [guestId], references: [id])

  @@map("transactions")
}

model Vendor {
  id          String    @id @default(uuid())
  name        String
  category    String    
  contact     String?
  contractUrl String?   
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())

  expenses    Expense[]

  @@map("vendors")
}

model Expense {
  id          String        @id @default(uuid())
  description String
  amount      Int           
  dueDate     DateTime
  status      ExpenseStatus @default(PENDING)
  createdAt   DateTime      @default(now())

  vendorId    String
  vendor      Vendor        @relation(fields: [vendorId], references: [id])

  @@map("expenses")
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?    @db.Text
  dueDate     DateTime?
  assignee    String?    
  status      TaskStatus @default(TODO)
  position    Int        
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("tasks")
}

model HoneymoonItem {
  id          String   @id @default(uuid())
  title       String
  category    String   
  amount      Int      
  isPaid      Boolean  @default(false)
  plannedDate DateTime?
  createdAt   DateTime @default(now())

  @@map("honeymoon_items")
}

model MessageTemplate {
  id        String   @id @default(uuid())
  name      String
  content   String   @db.Text
  mediaUrl  String?
  mediaType String?  // Ex: image, document, audio
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("message_templates")
}

model SystemSettings {
  id             String    @id @default("global")
  rsvpDeadline   DateTime?
  themeColor     String    @default("#18181b")
  heroImageUrl   String?
  welcomeText    String?   @db.Text
  updatedAt      DateTime  @updatedAt

  @@map("system_settings")
}

model Role {
  id           String   @id @default(uuid())
  name         String   @unique
  allowedPaths Json     // JSON string array de paths permitidos
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users        User[]

  @@map("roles")
}

model User {
  id        String   @id @default(uuid())
  name      String
  username  String   @unique
  password  String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}